# 数据库配置
# 开发环境使用 SQLite
DATABASE_URL="file:./dev.db"

# 生产环境使用 PostgreSQL（使用 Vercel Postgres 或自建数据库）
# DATABASE_URL="postgresql://user:password@host:5432/goalstack?schema=public"

# 可选：Redis 缓存（生产环境使用）
# REDIS_URL="redis://user:password@host:6379"

# 可选：Sentry 错误监控
# SENTRY_DSN="your-sentry-dsn"

# 可选：Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID="your-analytics-id"